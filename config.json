{
    "start_urls": [
        "https://example.com"
    ],
    "sitemaps": [],
    "max_pages": 20,
    "max_depth": 2,
    "max_concurrent": 5,
    "max_per_domain": 2,
    "rate_limit": 1.0,
    "respect_robots": true,
    "same_domain_only": true,
    "min_delay": 0.0,
    "jitter": 0.0,
    "user_agent": "MyCrawler/1.0",
    "exclude_patterns": [
        ".pdf",
        ".jpg",
        ".jpeg",
        ".png",
        ".gif",
        ".zip",
        ".tar",
        ".tar.bz2",
        ".bz2",
        ".gz",
        ".epub",
        "/login",
        "/admin"
    ],
    "include_patterns": [],
    "storage": {
        "type": "json",
        "filename": "results.jsonl",
        "mode": "jsonl",
        "indent": null,
        "batch_size": 10
    },
    "logging": {
        "filename": "crawler.log",
        "level": "INFO",
        "max_bytes": 1000000,
        "backup_count": 3
    }
}